### Target Vendor/Product (support only Ralink RT3883/MT7620/MT7621/MT7628)
CONFIG_VENDOR=NEWIFI
CONFIG_PRODUCT=MT7621

### Target ProductID (board select, max 12 symbols)
CONFIG_FIRMWARE_PRODUCT_ID="NEWIFI-D2"

############################################################
### Linux kernel configuration
############################################################

### Force MT7621 CPU clock to 900MHz (override Uboot settings)
#CONFIG_FIRMWARE_CPU_900MHZ=y

### Enable MT7621 CPU sleep mode (downclock to 220MHz on idle)
#CONFIG_FIRMWARE_CPU_SLEEP=y

### Kernel driver select for WiFi AP 2.4GHz
CONFIG_FIRMWARE_WIFI2_DRIVER=4.1

### Kernel driver select for WiFi AP 5GHz
CONFIG_FIRMWARE_WIFI5_DRIVER=3.0

### Enable IPv6 support ~0.2MB
CONFIG_FIRMWARE_ENABLE_IPV6=y

### Include XFRM (IPsec) modules & iptables extension ~ 0.2MB
#CONFIG_FIRMWARE_INCLUDE_XFRM=y

### Enable USB support (Giữ để cắm USB/Ổ cứng làm bộ nhớ đệm cho AdGuard Home)
CONFIG_FIRMWARE_ENABLE_USB=y

### Include file system utilities
CONFIG_FIRMWARE_INCLUDE_FS_TOOLS=n

### Disable heavy filesystems to save space
CONFIG_FIRMWARE_ENABLE_UFSD=n
CONFIG_FIRMWARE_ENABLE_FAT=y
CONFIG_FIRMWARE_ENABLE_EXFAT=n
CONFIG_FIRMWARE_ENABLE_EXT2=n
CONFIG_FIRMWARE_ENABLE_EXT3=n
CONFIG_FIRMWARE_ENABLE_EXT4=y
CONFIG_FIRMWARE_ENABLE_XFS=n
CONFIG_FIRMWARE_ENABLE_HFS=n
CONFIG_FIRMWARE_ENABLE_FUSE=y
CONFIG_FIRMWARE_ENABLE_SWAP=y

### Include UVC camera modules.
CONFIG_FIRMWARE_INCLUDE_UVC=n
#CONFIG_FIRMWARE_INCLUDE_HID=y
#CONFIG_FIRMWARE_INCLUDE_SERIAL=y
#CONFIG_FIRMWARE_INCLUDE_AUDIO=y

### 🔥 ĐÃ BẬT - Include network QoS scheduling modules. ~0.2MB
CONFIG_FIRMWARE_INCLUDE_QOS=y
CONFIG_FIRMWARE_INCLUDE_IMQ=y
CONFIG_FIRMWARE_INCLUDE_IFB=y

### Include TPROXY and IPSet (Cần thiết cho tường lửa và bộ lọc)
CONFIG_FIRMWARE_INCLUDE_TPROXY=y
CONFIG_FIRMWARE_INCLUDE_IPSET=y

### Tắt các tính năng chia sẻ mạng LAN để nhẹ máy
CONFIG_FIRMWARE_INCLUDE_NFSD=n
CONFIG_FIRMWARE_INCLUDE_NFSC=n
CONFIG_FIRMWARE_INCLUDE_CIFS=n
CONFIG_FIRMWARE_INCLUDE_SHORTCUT_FE=y

############################################################
### Userspace configuration
############################################################

### Tắt bớt ngôn ngữ thừa, chỉ giữ giao diện mặc định (Tiếng Anh/Nga theo gốc)
CONFIG_FIRMWARE_INCLUDE_LANG_RU=n
CONFIG_FIRMWARE_INCLUDE_VENDOR_LOGO=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_FIRMWARE_ENABLE_DNSMASQ_REGEX=y

### Tắt máy in, Samba, FTP server
CONFIG_FIRMWARE_INCLUDE_LPRD=n
CONFIG_FIRMWARE_INCLUDE_U2EC=n
CONFIG_FIRMWARE_INCLUDE_TCPDUMP=n
CONFIG_FIRMWARE_INCLUDE_HDPARM=n
CONFIG_FIRMWARE_INCLUDE_PARTED=n
CONFIG_FIRMWARE_INCLUDE_SMBD=n
CONFIG_FIRMWARE_INCLUDE_SMBD36=n
CONFIG_FIRMWARE_INCLUDE_FTPD=n

CONFIG_FIRMWARE_INCLUDE_RPL2TP=n
CONFIG_FIRMWARE_INCLUDE_EAP_PEAP=y
CONFIG_FIRMWARE_INCLUDE_DDNS_SSL=y
CONFIG_FIRMWARE_INCLUDE_HTTPS=y
CONFIG_FIRMWARE_INCLUDE_SFTP=n

### Dropbear SSH (Tối ưu mã hóa nhanh)
CONFIG_FIRMWARE_INCLUDE_DROPBEAR=y
CONFIG_FIRMWARE_INCLUDE_DROPBEAR_FAST_CODE=y

### 🔥 Tối ưu VPN: Tắt OpenVPN/StrongSwan nặng nề, Bật WireGuard siêu nhẹ
CONFIG_FIRMWARE_INCLUDE_OPENVPN=n
CONFIG_FIRMWARE_INCLUDE_SSWAN=n
CONFIG_FIRMWARE_INCLUDE_AMNEZIAWG=y
CONFIG_FIRMWARE_INCLUDE_WIREGUARD=y
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EC=y
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EXE=n

### Tắt Media Server và các trình Download Torrent/Aria2 ăn RAM
CONFIG_FIRMWARE_INCLUDE_XUPNPD=n
CONFIG_FIRMWARE_INCLUDE_MINIDLNA=n
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION=n
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION_WEB_CONTROL=n
CONFIG_FIRMWARE_INCLUDE_ARIA=n
CONFIG_FIRMWARE_INCLUDE_ARIA_WEB_CONTROL=n

### Tắt các Proxy mã hóa trùng lặp (Vì AdGuard Home sẽ đảm nhiệm DNS ngon hơn)
CONFIG_FIRMWARE_INCLUDE_TOR=n
CONFIG_FIRMWARE_INCLUDE_PRIVOXY=n
CONFIG_FIRMWARE_INCLUDE_DNSCRYPT=n
CONFIG_FIRMWARE_INCLUDE_STUBBY=n
CONFIG_FIRMWARE_INCLUDE_DOH=n
CONFIG_FIRMWARE_INCLUDE_CURL=y
CONFIG_FIRMWARE_INCLUDE_QUIC=n

### Hệ thống bổ trợ ổn định
CONFIG_FIRMWARE_INCLUDE_WPAD=y
CONFIG_FIRMWARE_INCLUDE_ZRAM=y
CONFIG_FIRMWARE_INCLUDE_ADB=n
CONFIG_FIRMWARE_INCLUDE_LUA=n
CONFIG_FIRMWARE_INCLUDE_EOIP=n
CONFIG_FIRMWARE_INCLUDE_ZAPRET=n
CONFIG_FIRMWARE_INCLUDE_ZAPRET2=n
